---
const experiences = [
  {
    title: "Software Engineer",
    company: "NICE Ltd.",
    type: "Enterprise Software",
    period: "Nov 2025 – Present",
    current: true,
    bullets: [
      "Contributed to a large-scale legacy .NET monolith, supporting refactoring efforts and resolving bugs across the codebase.",
      "Participated in frontend migrations from the monolith to Angular and React, building new features and fixing issues during the transition.",
      "Automated test cases in Selenium and Playwright and executed regression test sets, tracking coverage across release cycles.",
      "Built custom AI agents, skills, and commands using Claude Code to automate repetitive development workflows and improve team efficiency.",
    ],
    tags: [".NET", "Angular", "React", "Claude Code", "AI Agents"],
  },
  {
    title: "Software Engineer",
    company: "CIN",
    type: "Beverage Distribution Company",
    period: "Jan 2025 – Oct 2025",
    current: false,
    bullets: [
      "Designed and maintained relational databases (SQL Server, PostgreSQL) across multiple business systems covering purchases, sales, distribution, inventory, and HR.",
      "Implemented event-driven inter-system communication using MassTransit and RabbitMQ, enabling reliable message exchange across services.",
      "Developed and maintained backend services using Java + Spring Boot and C# + .NET, with React + TypeScript on the frontend side.",
    ],
    tags: ["Java", "Spring Boot", ".NET", "React", "RabbitMQ", "MassTransit", "PostgreSQL"],
  },
];
---

<section id="experience" class="py-24 bg-white">
  <div class="max-w-6xl mx-auto px-6">

    <div class="section-header text-center mb-16 opacity-0 translate-y-8 transition-all duration-700">
      <p class="text-blue-600 font-semibold text-sm tracking-widest uppercase mb-2">Where I've worked</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900">Experience</h2>
    </div>

    <div class="relative">
      <!-- Timeline line -->
      <div class="hidden md:block absolute left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-blue-200 via-slate-200 to-transparent -translate-x-1/2"></div>

      <div class="space-y-10">
        {experiences.map((exp, i) => (
          <div
            class={`exp-card relative flex flex-col md:flex-row gap-6 md:gap-10 opacity-0 translate-y-8 transition-all duration-700`}
            style={`transition-delay: ${i * 120}ms`}
          >
            <!-- Timeline dot (desktop) -->
            <div class="hidden md:flex absolute left-1/2 top-6 -translate-x-1/2 z-10">
              <div class={`w-4 h-4 rounded-full border-2 border-white shadow ${exp.current ? 'bg-blue-600' : 'bg-slate-300'}`}></div>
            </div>

            <!-- Left: date (desktop) -->
            <div class="hidden md:flex md:w-1/2 justify-end pr-10 pt-5">
              <div class="text-right">
                <span class={`inline-block text-sm font-semibold px-3 py-1 rounded-full ${exp.current ? 'bg-blue-50 text-blue-600' : 'bg-slate-100 text-slate-500'}`}>
                  {exp.period}
                </span>
              </div>
            </div>

            <!-- Right: card -->
            <div class="md:w-1/2 md:pl-10">
              <div class="bg-white border border-slate-100 rounded-2xl p-6 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-300">
                <!-- Mobile date -->
                <span class={`md:hidden inline-block text-xs font-semibold px-2.5 py-1 rounded-full mb-3 ${exp.current ? 'bg-blue-50 text-blue-600' : 'bg-slate-100 text-slate-500'}`}>
                  {exp.period}
                </span>

                <div class="flex items-start justify-between gap-3 mb-1">
                  <h3 class="text-base font-bold text-slate-900">{exp.title}</h3>
                  {exp.current && (
                    <span class="flex-shrink-0 text-xs font-semibold text-green-600 bg-green-50 px-2 py-0.5 rounded-full">Current</span>
                  )}
                </div>
                <p class="text-sm font-semibold text-blue-600 mb-0.5">{exp.company}</p>
                {exp.type && <p class="text-xs text-slate-400 mb-4">{exp.type}</p>}
                {!exp.type && <div class="mb-4" />}

                <ul class="space-y-2 mb-4">
                  {exp.bullets.map((bullet) => (
                    <li class="flex gap-2.5 text-sm text-slate-600 leading-relaxed">
                      <span class="text-blue-400 mt-1 flex-shrink-0">▸</span>
                      <span>{bullet}</span>
                    </li>
                  ))}
                </ul>

                <div class="flex flex-wrap gap-1.5">
                  {exp.tags.map((tag) => (
                    <span class="text-xs font-medium text-slate-500 bg-slate-50 border border-slate-200 px-2.5 py-1 rounded-lg">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.remove("opacity-0", "translate-y-8");
          entry.target.classList.add("opacity-100", "translate-y-0");
        }
      });
    },
    { threshold: 0.1 }
  );

  document.querySelectorAll("#experience .section-header, #experience .exp-card").forEach((el) => {
    observer.observe(el);
  });
</script>
