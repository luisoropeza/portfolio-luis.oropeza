---
const projects = [
  {
    title: "Inventory Management System",
    status: "In Development",
    period: "2025 – Present",
    type: "Personal Project",
    description:
      "Designing the system to grow with new business modules over time, with emphasis on backend architecture, database modeling, JWT authentication, and SOLID principles.",
    tags: [".NET", "Angular", "PostgreSQL", "JWT", "SOLID"],
    icon: "📦",
    accent: "blue",
  },
  {
    title: "Leave & Absence Management System",
    status: "Completed",
    period: "2024",
    type: "Postgraduate Diploma Project",
    description:
      "Built the backend with Spring Boot — JWT authentication, REST API design, and relational database modeling. Developed the frontend with Vue.js, integrating views and forms with the backend API.",
    tags: ["Spring Boot", "Vue.js", "PostgreSQL", "REST API", "JWT"],
    icon: "📅",
    accent: "violet",
  },
];

const accentMap: Record<string, { badge: string; tag: string; icon: string }> = {
  blue: {
    badge: "bg-amber-50 text-amber-600 border border-amber-200",
    tag: "bg-blue-50 text-blue-700 border-blue-100",
    icon: "bg-blue-100 text-blue-600",
  },
  violet: {
    badge: "bg-emerald-50 text-emerald-600 border border-emerald-200",
    tag: "bg-violet-50 text-violet-700 border-violet-100",
    icon: "bg-violet-100 text-violet-600",
  },
};
---

<section id="projects" class="py-24 bg-slate-50">
  <div class="max-w-6xl mx-auto px-6">

    <div class="section-header text-center mb-16 opacity-0 translate-y-8 transition-all duration-700">
      <p class="text-blue-600 font-semibold text-sm tracking-widest uppercase mb-2">What I've built</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900">Projects</h2>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      {projects.map((project, i) => {
        const acc = accentMap[project.accent];
        return (
          <div
            class={`project-card bg-white rounded-2xl p-7 border border-slate-100 shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all duration-300 opacity-0 translate-y-8 flex flex-col`}
            style={`transition-delay: ${i * 120}ms`}
          >
            <div class="flex items-start justify-between gap-4 mb-5">
              <div class={`w-12 h-12 rounded-xl flex items-center justify-center text-2xl ${acc.icon}`}>
                {project.icon}
              </div>
              <span class={`text-xs font-semibold px-2.5 py-1 rounded-full ${acc.badge}`}>
                {project.status}
              </span>
            </div>

            <div class="mb-1 flex items-baseline gap-2">
              <h3 class="text-lg font-bold text-slate-900">{project.title}</h3>
            </div>
            <p class="text-xs text-slate-400 mb-1">{project.type}</p>
            <p class="text-xs font-medium text-slate-400 mb-4">{project.period}</p>

            <p class="text-sm text-slate-600 leading-relaxed mb-6 flex-1">
              {project.description}
            </p>

            <div class="flex flex-wrap gap-2">
              {project.tags.map((tag) => (
                <span class={`text-xs font-medium px-3 py-1 rounded-lg border ${acc.tag}`}>
                  {tag}
                </span>
              ))}
            </div>
          </div>
        );
      })}
    </div>

  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.remove("opacity-0", "translate-y-8");
          entry.target.classList.add("opacity-100", "translate-y-0");
        }
      });
    },
    { threshold: 0.1 }
  );

  document.querySelectorAll("#projects .section-header, #projects .project-card").forEach((el) => {
    observer.observe(el);
  });
</script>
