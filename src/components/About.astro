---
---

<section id="about" class="py-24 bg-white">
  <div class="max-w-6xl mx-auto px-6">

    <div class="section-header text-center mb-16 opacity-0 translate-y-8 transition-all duration-700">
      <p class="text-blue-600 font-semibold text-sm tracking-widest uppercase mb-2">Who I am</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900">About Me</h2>
    </div>

    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div class="space-y-5 opacity-0 translate-y-8 transition-all duration-700 delay-100">
        <p class="text-slate-600 text-lg leading-relaxed">
          Software Engineer with experience building business and enterprise applications across the full stack.
          Strong background in backend development — API design, relational database modeling, and event-driven
          communication — with hands-on frontend experience in Angular, React.
        </p>
        <p class="text-slate-600 leading-relaxed">
          At <span class="font-semibold text-slate-800">NICE</span>, I worked on the backend of a .NET monolith application,
          where I delivered epic stories and refactored APIs to make the code better. I also helped the team migrate our
          frontend to Angular and React. During this migration, my main job was to support the process and fix the bugs
          that appeared during the transition. I also used AI agents and Claude Code to help improve our daily workflow.
        </p>
        <p class="text-slate-600 leading-relaxed">
          At <span class="font-semibold text-slate-800">CIN</span>, I worked with a mix of technologies like Spring Boot,
          .NET, and React. I was highly involved in designing the architecture of the projects. My biggest task there
          was connecting different business systems so they could talk to each other, which I did by implementing
          RabbitMQ and MassTransit.
        </p>
      </div>

      <div class="grid grid-cols-2 gap-4 opacity-0 translate-y-8 transition-all duration-700 delay-200">
        {[
          { label: "Location", value: "Cochabamba, Bolivia", icon: "📍" },
          { label: "Languages", value: "Spanish (Native)\nEnglish (B1)", icon: "🌐" },
          { label: "Availability", value: "Open to opportunities", icon: "✅" },
          { label: "Focus", value: "Backend & Full Stack", icon: "⚙️" },
        ].map((item) => (
          <div class="bg-slate-50 rounded-2xl p-5 border border-slate-100 hover:border-blue-200 hover:bg-blue-50/30 transition-all duration-200">
            <span class="text-2xl mb-2 block">{item.icon}</span>
            <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-1">{item.label}</p>
            <p class="text-sm font-medium text-slate-700 whitespace-pre-line">{item.value}</p>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.remove("opacity-0", "translate-y-8");
          entry.target.classList.add("opacity-100", "translate-y-0");
        }
      });
    },
    { threshold: 0.15 }
  );

  document.querySelectorAll("#about .section-header, #about .opacity-0").forEach((el) => {
    observer.observe(el);
  });
</script>
