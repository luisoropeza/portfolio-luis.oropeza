---
const skillGroups = [
  {
    category: "Backend",
    icon: "⚙️",
    color: "blue",
    skills: [".NET / C#", "Spring Boot", "Java", "Kotlin", "REST APIs", "JWT"],
  },
  {
    category: "Frontend",
    icon: "🖥️",
    color: "violet",
    skills: ["Angular", "React.js", "Vue.js", "TypeScript", "JavaScript", "HTML & CSS"],
  },
  {
    category: "Databases",
    icon: "🗄️",
    color: "emerald",
    skills: ["SQL Server", "PostgreSQL"],
  },
  {
    category: "Messaging",
    icon: "📨",
    color: "orange",
    skills: ["RabbitMQ", "MassTransit"],
  },
  {
    category: "Cloud & DevOps",
    icon: "☁️",
    color: "sky",
    skills: ["Docker", "Git", "AWS EC2", "AWS S3"],
  },
  {
    category: "AI & Tooling",
    icon: "🤖",
    color: "rose",
    skills: ["Claude Code", "AI Agents", "Prompt Engineering", "Test Automation"],
  },
];

const colorMap: Record<string, string> = {
  blue:    "bg-blue-50 text-blue-700 border-blue-100 hover:bg-blue-100",
  violet:  "bg-violet-50 text-violet-700 border-violet-100 hover:bg-violet-100",
  emerald: "bg-emerald-50 text-emerald-700 border-emerald-100 hover:bg-emerald-100",
  orange:  "bg-orange-50 text-orange-700 border-orange-100 hover:bg-orange-100",
  sky:     "bg-sky-50 text-sky-700 border-sky-100 hover:bg-sky-100",
  rose:    "bg-rose-50 text-rose-700 border-rose-100 hover:bg-rose-100",
};

const headerColorMap: Record<string, string> = {
  blue:    "text-blue-600",
  violet:  "text-violet-600",
  emerald: "text-emerald-600",
  orange:  "text-orange-600",
  sky:     "text-sky-600",
  rose:    "text-rose-600",
};
---

<section id="skills" class="py-24 bg-slate-50">
  <div class="max-w-6xl mx-auto px-6">

    <div class="section-header text-center mb-16 opacity-0 translate-y-8 transition-all duration-700">
      <p class="text-blue-600 font-semibold text-sm tracking-widest uppercase mb-2">What I work with</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900">Technical Skills</h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {skillGroups.map((group, i) => (
        <div
          class={`skill-card bg-white rounded-2xl p-6 border border-slate-100 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300 opacity-0 translate-y-8`}
          style={`transition-delay: ${i * 80}ms`}
        >
          <div class="flex items-center gap-3 mb-4">
            <span class="text-2xl">{group.icon}</span>
            <h3 class={`font-bold text-base ${headerColorMap[group.color]}`}>{group.category}</h3>
          </div>
          <div class="flex flex-wrap gap-2">
            {group.skills.map((skill) => (
              <span class={`text-xs font-medium px-3 py-1.5 rounded-lg border transition-colors duration-200 ${colorMap[group.color]}`}>
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.remove("opacity-0", "translate-y-8");
          entry.target.classList.add("opacity-100", "translate-y-0");
        }
      });
    },
    { threshold: 0.1 }
  );

  document.querySelectorAll("#skills .section-header, #skills .skill-card").forEach((el) => {
    observer.observe(el);
  });
</script>
