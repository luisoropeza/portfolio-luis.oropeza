---
---

<section
  id="hero"
  class="min-h-screen flex items-center pt-20 bg-gradient-to-br from-slate-50 via-white to-blue-50"
>
  <div class="max-w-6xl mx-auto px-6 w-full">
    <div class="flex flex-col-reverse md:flex-row items-center gap-12 md:gap-16">

      <!-- Text -->
      <div class="flex-1 text-center md:text-left">
        <p
          class="text-blue-600 font-semibold text-sm tracking-widest uppercase mb-4 opacity-0 animate-fade-up"
          style="animation-delay: 0.1s; animation-fill-mode: forwards;"
        >
          Software Engineer
        </p>
        <h1
          class="text-4xl sm:text-5xl lg:text-6xl font-bold text-slate-900 leading-tight mb-6 opacity-0 animate-fade-up"
          style="animation-delay: 0.2s; animation-fill-mode: forwards;"
        >
          Luis David<br />
          <span class="text-blue-600">Oropeza</span> Cordova
        </h1>
        <p
          class="text-slate-500 text-lg leading-relaxed max-w-xl mx-auto md:mx-0 mb-8 opacity-0 animate-fade-up"
          style="animation-delay: 0.35s; animation-fill-mode: forwards;"
        >
          Software Engineer with experience building business and enterprise applications
          across the full stack. Strong background in backend development and event-driven systems.
        </p>

        <div
          class="flex flex-wrap gap-3 justify-center md:justify-start opacity-0 animate-fade-up"
          style="animation-delay: 0.5s; animation-fill-mode: forwards;"
        >
          <a
            href="#contact"
            class="px-6 py-3 bg-blue-600 text-white text-sm font-semibold rounded-xl hover:bg-blue-700 transition-all duration-200 shadow-md shadow-blue-200 hover:shadow-lg hover:shadow-blue-300 hover:-translate-y-0.5"
          >
            Get in touch
          </a>
          <a
            href="#experience"
            class="px-6 py-3 bg-white text-slate-700 text-sm font-semibold rounded-xl border border-slate-200 hover:border-blue-300 hover:text-blue-600 transition-all duration-200 hover:-translate-y-0.5"
          >
            View experience
          </a>
        </div>

        <!-- Social links -->
        <div
          class="flex gap-4 justify-center md:justify-start mt-8 opacity-0 animate-fade-up"
          style="animation-delay: 0.65s; animation-fill-mode: forwards;"
        >
          <a
            href="https://linkedin.com/in/luis-david-oropeza-cordova"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 text-slate-500 hover:text-blue-600 text-sm font-medium transition-colors duration-200"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            LinkedIn
          </a>
          <a
            href="https://github.com/luisoropeza"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 text-slate-500 hover:text-slate-900 text-sm font-medium transition-colors duration-200"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
            </svg>
            GitHub
          </a>
        </div>
      </div>

      <!-- Photo -->
      <div
        class="flex-shrink-0 opacity-0 animate-fade-up"
        style="animation-delay: 0.15s; animation-fill-mode: forwards;"
      >
        <div class="relative">
          <div class="w-56 h-56 md:w-72 md:h-72 rounded-3xl overflow-hidden ring-4 ring-white shadow-2xl shadow-slate-200">
            <img
              src="/profile.png"
              alt="Luis David Oropeza Cordova"
              class="w-full h-full object-cover"
            />
          </div>
          <!-- Decorative accent -->
          <div class="absolute -bottom-4 -right-4 w-24 h-24 bg-blue-100 rounded-2xl -z-10"></div>
          <div class="absolute -top-4 -left-4 w-16 h-16 bg-slate-100 rounded-2xl -z-10"></div>
        </div>
      </div>

    </div>

    <!-- Scroll indicator -->
    <div class="flex justify-center mt-20 opacity-0 animate-fade-up" style="animation-delay: 0.8s; animation-fill-mode: forwards;">
      <a href="#about" class="flex flex-col items-center gap-2 text-slate-400 hover:text-blue-500 transition-colors duration-200 group">
        <span class="text-xs tracking-widest uppercase font-medium">Scroll</span>
        <div class="w-px h-8 bg-gradient-to-b from-slate-300 to-transparent group-hover:from-blue-400 transition-colors duration-200"></div>
      </a>
    </div>
  </div>
</section>
